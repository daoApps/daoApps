# ============================================
# Flexloop Vue3 前端应用 - 多阶段构建
# ============================================
#
# 多平台构建示例（使用 buildx）:
#   # Linux amd64 + arm64 双架构构建
#   podman build --platform linux/amd64,linux/arm64 -t flexloop:latest .
#
#   # 使用 buildx 进行多平台构建并推送到仓库
#   docker buildx build --platform linux/amd64,linux/arm64 -t your-registry/flexloop:latest --push .
#
#   # 单平台构建（默认）
#   podman build -t flexloop:latest .
# ============================================

# ============================================
# 阶段 1: 构建阶段 - 安装依赖并编译项目
# ============================================
FROM node:20-alpine AS build

ARG NODE_VERSION=20

LABEL org.opencontainers.image.title="Flexloop Build Stage"
LABEL org.opencontainers.image.description="Build stage for Flexloop Vue3 frontend application"
LABEL org.opencontainers.image.source="https://github.com/daoCollective/Flexloop"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.licenses="MIT"

WORKDIR /app

RUN npm config set cache /tmp/npm-cache

COPY package.json package-lock.json ./

RUN npm ci --prefer-offline

COPY tsconfig*.json ./
COPY vite.config.ts ./
COPY postcss.config.js ./
COPY tailwind.config.ts ./

COPY . .

ENV NODE_ENV=production

RUN npm run build \
    && npm cache clean --force \
    && rm -rf /tmp/npm-cache

# ============================================
# 阶段 2: 生产阶段 - 使用 Nginx 提供服务
# ============================================
FROM nginx:alpine AS production

LABEL maintainer="Flexloop Team"
LABEL description="Flexloop Vue3 前端应用"
LABEL version="1.0.0"
LABEL org.opencontainers.image.title="Flexloop Production"
LABEL org.opencontainers.image.description="Production image for Flexloop Vue3 frontend with Nginx"
LABEL org.opencontainers.image.version="1.0.0"

RUN apk add --no-cache curl

RUN rm /etc/nginx/conf.d/default.conf

COPY nginx.conf /etc/nginx/conf.d/default.conf

COPY --from=build /app/dist /usr/share/nginx/html

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

RUN chown -R appuser:appgroup /usr/share/nginx/html \
    && chown -R appuser:appgroup /var/cache/nginx \
    && chown -R appuser:appgroup /var/log/nginx \
    && touch /var/run/nginx.pid \
    && chown -R appuser:appgroup /var/run/nginx.pid

USER appuser

EXPOSE 80

ENV NODE_ENV=production
ENV TZ=Asia/Shanghai

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl --fail http://localhost:80/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
