# ============================================================
# AgentPit 生产环境配置模板 (.env.production.example)
# ============================================================
#
# 📋 使用说明:
# 1. 复制此文件为 .env.production
#    cp .env.production.example .env.production
#
# 2. 根据实际部署环境修改以下配置项
#
# 3. ⚠️ 安全提醒:
#    - 此文件仅作为模板参考，可安全提交到版本库
#    - 生成的 .env.production 包含真实配置，请勿提交
#    - 敏感信息应通过 CI/CD 环境变量或密钥管理服务注入
#
# 4. 🔧 部署检查清单:
#    [ ] 确认 API_BASE_URL 指向正确的生产服务器
#    [ ] 确认 USE_MOCK_API 设置为 false
#    [ ] 验证 API_TIMEOUT 符合生产环境需求
#    [ ] 确认时区设置正确
#
# ============================================================

# Node.js 运行环境 (固定值，请勿修改)
NODE_ENV=production

# ----------------------------------------------------------
# API 配置 (必须修改)
# ----------------------------------------------------------

# API 基础地址 (生产环境)
# ⚠️ 必须替换为实际的 production API 地址
# 格式: https://your-production-domain.com/api
VITE_API_BASE_URL=https://api.agentpit.com/api

# API 请求超时时间 (毫秒)
# 建议: 生产环境使用 30000ms (30秒) 以应对网络波动
# 可根据实际情况调整: 15000-60000ms
VITE_API_TIMEOUT=30000

# 是否使用 Mock 数据
# ⚠️ 生产环境必须设置为 false
# true = 使用模拟数据 (仅用于开发/测试)
# false = 连接真实后端 API (生产环境必需)
VITE_USE_MOCK_API=false

# ----------------------------------------------------------
# 时区配置
# ----------------------------------------------------------

# 服务器时区设置
# 用于:
#   - 日志时间戳格式化
#   - 定时任务调度
#   - 数据库时间字段
# 常用值: Asia/Shanghai, UTC, America/New_York
TZ=Asia/Shanghai

# ============================================================
# 📌 高级配置 (可选)
# ============================================================
# 以下配置项根据实际需求取消注释并配置

# # CORS 允许的源 (如需前端直接调用其他域名 API)
# VITE_CORS_ORIGINS=https://app.agentpit.com

# # 启用性能监控 (如需接入 Sentry/GA 等)
# VITE_ENABLE_MONITORING=true
# VITE_SENTRY_DSN=

# # CDN 资源地址 (如使用 CDN 加速静态资源)
# VITE_CDN_BASE_URL=https://cdn.agentpit.com
