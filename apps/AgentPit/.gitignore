node_modules
dist
dist-ssr
*.local

# Environment files
# ============================================================
# ⚠️ 安全策略说明:
# -----------------------------------------------------------
# ❌ 以下文件包含敏感信息，绝对不能提交到版本库:
#    .env.production        - 生产环境真实配置 (含 API 地址等)
#    .env.local             - 本地开发覆盖配置
#    .env.*.local           - 各环境本地覆盖配置
#
# ✅ 以下文件可以安全提交 (仅作为模板/参考):
#    .env.development       - 开发环境默认配置 (无敏感信息)
#    .env.production.example- 生产环境模板 (含占位符)
#    .env.example           - 通用示例配置
# ============================================================
.env.local
.env.*.local

# 生产环境配置 (包含真实的 API 地址和密钥)
.env.production

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# ============================================
# 敏感信息保护（Skills 安全增强）
# ============================================

# 环境变量文件（含真实凭证 - 绝不提交）
.env.staging
!.env.example
!.env.development
!.env.skills.template

# 密钥和证书
*.key
*.pem
credentials.json
secrets.yaml
secrets.yml

# 操作系统文件
Thumbs.db
desktop.ini

# 临时文件
*.tmp
*.temp
.cache/
agentpit.zip
